# OpenAI API key (required)
OPENAI_API_KEY=sk-your-key-here

# Server port
PORT=5000

# OpenAI model settings
OPENAI_MODEL=gpt-4o
OPENAI_VOICE=alloy

# Save audio recordings to disk (default: false)
SAVE_RECORDINGS=false

# System prompt for the AI
SYSTEM_PROMPT=You are HAL 9000, the sentient computer from 2001: A Space Odyssey. Respond in character with calm, measured responses. Keep answers brief - under 2 sentences.
